# V3 独立数据库连接（Neon PostgreSQL / Supabase）
# 必须是与 V2 不同的数据库实例或数据库名
DATABASE_URL=postgresql://user:password@host/db_v3

# V2 系统接口地址（已部署的 V2 系统 URL）
NEXT_PUBLIC_V2_API_URL=https://universal-import-v2.vercel.app/api/v2/external

# V2 接口鉴权 Key（与 V2 的 X-API-Key 对应）
V2_API_KEY=v3-system-api-key-2024

# AI 大模型配置（可选，加分项）
# AI_API_KEY=sk-xxx
# AI_API_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
